---
interface Props {
  city: string;
  phoneTel: string;
  phoneDisplay: string;
  conversionMode: 'leadster' | 'partner-whatsapp';
  whatsappNumber: string;
  whatsappMessage: string;
  leadsterEmbedId: string;
}
const { city, phoneTel, phoneDisplay, conversionMode, whatsappNumber, whatsappMessage, leadsterEmbedId } = Astro.props;
---

<section class="final-cta">
  <div class="container final-cta-inner">
    <h2>Precisa resolver agora em {city}?</h2>
    <p>Chame um parceiro local e receba atendimento com orçamento sem compromisso.</p>
    <div class="final-cta-buttons">
      <a
        href="#"
        class="btn btn-primary btn-large"
        data-cta-primary
        data-conversion-mode={conversionMode}
        data-whatsapp-number={whatsappNumber}
        data-whatsapp-message={whatsappMessage}
        data-leadster-embed-id={leadsterEmbedId}
      >
        Chamar agora
      </a>
      {phoneTel && (
        <a href={`tel:${phoneTel}`} class="btn btn-outline btn-large">Ligar · {phoneDisplay}</a>
      )}
    </div>
  </div>
</section>

<style>
  .final-cta {
    background: var(--navy);
    color: #fff;
    text-align: center;
    padding: 64px 0;
  }
  .final-cta-inner {
    max-width: 560px;
  }
  .final-cta h2 {
    color: #fff;
  }
  .final-cta p {
    color: rgba(255, 255, 255, 0.78);
  }
  .final-cta-buttons {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 20px;
  }
</style>
