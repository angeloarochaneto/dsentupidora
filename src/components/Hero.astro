---
import { capitalize } from '../lib/seo';

interface Props {
  mode: 'standard' | 'urgency' | 'bairro';
  city: string;
  bairro?: string;
  keyword: string;
  phoneTel: string;
  phoneDisplay: string;
  conversionMode: 'leadster' | 'partner-whatsapp';
  whatsappNumber: string;
  whatsappMessage: string;
  leadsterEmbedId: string;
  kpis: { num: string; lbl: string }[];
  heroImage?: { url: string; alt: string };
  neighborhoods?: { bairro: string }[];
}

const {
  mode,
  city,
  bairro,
  keyword,
  phoneTel,
  phoneDisplay,
  conversionMode,
  whatsappNumber,
  whatsappMessage,
  leadsterEmbedId,
  kpis,
  heroImage,
  neighborhoods = [],
} = Astro.props;

const neighborhoodNames = neighborhoods.map((n) => n.bairro);

const image = heroImage ?? { url: '/images/hero-placeholder.jpg', alt: `Equipe de ${keyword} atendendo em ${city}` };

const kw = capitalize(keyword);

let h1Prefix = `${kw} em `;
let h1Location = city;
let h1Suffix = '.';
let lead = `Entupiu? A gente aciona um parceiro local perto de você, com orçamento sem compromisso.`;

if (mode === 'urgency') {
  h1Prefix = `${kw} 24h em `;
  h1Location = city;
  h1Suffix = ': atendimento agora, dia e noite.';
  lead = `Problema não espera. Plantão todos os dias, inclusive fins de semana e feriados, em ${city}.`;
} else if (mode === 'bairro' && bairro) {
  h1Prefix = `${kw} no `;
  h1Location = bairro;
  h1Suffix = ` de ${city}.`;
  lead = `Atendimento local rápido no ${bairro}, com equipe que conhece a região.`;
}

const checks = ['Orçamento sem compromisso', 'Sem quebra-quebra', 'Equipe própria', 'Garantia por escrito'];
---

<section class="hero">
  <div class="hero__bg">
    <img src={image.url} alt={image.alt} width="1600" height="900" />
  </div>

  <div class="container hero-inner">
    <div class="hero-copy">
      <span class="eyebrow">Plantão 24h</span>
      <h1>{h1Prefix}<em>{h1Location}</em>{h1Suffix}</h1>
      <p class="hero-lead">{lead}</p>

      <div class="hero-ctas">
        <a
          href="#"
          class="btn btn-primary btn-large"
          data-cta-primary
          data-conversion-mode={conversionMode}
          data-whatsapp-number={whatsappNumber}
          data-whatsapp-message={whatsappMessage}
          data-leadster-embed-id={leadsterEmbedId}
        >
          Chamar agora
        </a>
        {phoneTel && (
          <a href={`tel:${phoneTel}`} class="btn btn-outline btn-large">Ligar · {phoneDisplay}</a>
        )}
      </div>

      <ul class="hero-checks">
        {checks.map((c) => (
          <li>✓ {c}</li>
        ))}
      </ul>

      {neighborhoodNames.length > 0 && (
        <p class="hero-neighborhoods">
          Atendemos {city} inteira: {neighborhoodNames.join(', ')} e região.
        </p>
      )}
    </div>
  </div>

  <div class="hero-badge">Chegada estimada: 30–40 min</div>

  <div class="container">
    <div class="kpi-strip">
      {kpis.map((k) => (
        <div class="kpi-item">
          <span class="kpi-num">{k.num}</span>
          <span class="kpi-lbl">{k.lbl}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    color: #fff;
    padding: 72px 0 0;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(100deg, rgba(7, 27, 54, 0.95) 0%, rgba(7, 27, 54, 0.88) 38%, rgba(7, 27, 54, 0.5) 75%, rgba(7, 27, 54, 0.35) 100%);
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    padding-bottom: 56px;
  }
  .hero-copy {
    max-width: 620px;
  }
  .hero h1 {
    color: #fff;
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: 18px;
  }
  .hero h1 em {
    font-style: italic;
    font-weight: 800;
    color: var(--amber);
  }
  .hero-lead {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.05rem;
    max-width: 480px;
  }
  .hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin: 24px 0;
  }
  .hero-checks {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .hero-checks li {
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.92rem;
    font-weight: 600;
  }
  .hero-neighborhoods {
    margin: 18px 0 0;
    padding-top: 18px;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.85rem;
    max-width: 480px;
  }
  .hero-badge {
    position: absolute;
    z-index: 1;
    bottom: 130px;
    right: 24px;
    background: #fff;
    color: var(--navy);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    padding: 10px 16px;
    border-radius: 999px;
    box-shadow: var(--shadow-md);
  }
  .kpi-strip {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding: 24px 0 32px;
  }
  .kpi-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .kpi-num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.6rem;
    color: var(--amber);
  }
  .kpi-lbl {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.7);
  }
  @media (max-width: 900px) {
    .kpi-strip {
      grid-template-columns: repeat(2, 1fr);
    }
    .hero-badge {
      bottom: auto;
      top: 16px;
      right: 16px;
    }
  }
</style>
