---
interface Props {
  city: string;
  phoneDisplay: string;
}
const { city, phoneDisplay } = Astro.props;
---

<div class="announce-bar">
  <div class="container">
    <span>⚡ ATENDIMENTO 24H · {city.toUpperCase()} E REGIÃO{phoneDisplay && ` · ${phoneDisplay}`}</span>
  </div>
</div>

<style>
  .announce-bar {
    background: var(--navy);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 8px 0;
    text-align: center;
  }
</style>
