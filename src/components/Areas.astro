---
interface Neighborhood {
  bairro: string;
  desc: string;
}
interface Props {
  neighborhoods: Neighborhood[];
}
const { neighborhoods } = Astro.props;
---

{neighborhoods.length > 0 && (
  <section class="section section--panel" id="areas">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Áreas atendidas</span>
        <h2>Onde a gente chega</h2>
      </div>
      <div class="grid grid-3">
        {neighborhoods.map((n) => (
          <div class="card area-card">
            <h3>{n.bairro}</h3>
            <p>{n.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .area-card p {
    color: var(--muted);
    font-size: 0.9rem;
    margin: 0;
  }
</style>
