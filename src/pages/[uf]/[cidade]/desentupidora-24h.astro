---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import AnnounceBar from '../../../components/AnnounceBar.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import Hero from '../../../components/Hero.astro';
import UrgencyInfo from '../../../components/UrgencyInfo.astro';
import Services from '../../../components/Services.astro';
import Differentials from '../../../components/Differentials.astro';
import Steps from '../../../components/Steps.astro';
import Areas from '../../../components/Areas.astro';
import Testimonials from '../../../components/Testimonials.astro';
import FinalCTA from '../../../components/FinalCTA.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import StickyMobileCta from '../../../components/StickyMobileCta.astro';
import { buildTitle, buildDescription, buildBreadcrumbSchema, buildPlumberSchema, buildFaqSchema } from '../../../lib/seo';

export async function getStaticPaths() {
  const cities = await getCollection('cities');
  return cities.map((entry) => ({
    params: { uf: entry.data.slugUf, cidade: entry.data.slugCity },
    props: { city: entry },
  }));
}

const { city } = Astro.props;
const data = city.data;

const whatsappMessage = data.whatsapp.message.replace('{{CIDADE}}', data.city);

const title = buildTitle(data.keyword, data.city, '24h Emergência');
const description = buildDescription(
  data.keyword,
  data.city,
  data.phone.display,
  `plantão 24h, atendimento agora mesmo, dia e noite.`,
);

const urgencyFaqs = [
  {
    q: 'Cobram taxa extra pra atender de madrugada ou fim de semana?',
    a: 'O valor do plantão 24h é informado no orçamento antes do início do serviço, sem taxa surpresa depois.',
  },
  {
    q: 'Atendem feriado?',
    a: `Sim, o plantão em ${data.city} funciona todos os dias do ano, incluindo feriados.`,
  },
  {
    q: `Quanto tempo demora a equipe chegar à noite em ${data.city}?`,
    a: 'O tempo de chegada é o mesmo estimado durante o dia — a equipe de plantão já está de prontidão.',
  },
];

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const breadcrumb = buildBreadcrumbSchema([
  { name: 'Início', url: new URL('/', Astro.site).toString() },
  { name: data.uf, url: new URL(`/${data.slugUf}/`, Astro.site).toString() },
  { name: data.city, url: new URL(`/${data.slugUf}/${data.slugCity}/`, Astro.site).toString() },
  { name: `${data.keyword} 24h`, url: pageUrl },
]);
const plumberSchema = buildPlumberSchema({
  partnerName: data.partner.name,
  phoneDisplay: data.phone.display,
  address: data.partner.address,
  city: data.city,
  uf: data.uf,
  url: pageUrl,
});
const faqSchema = buildFaqSchema(urgencyFaqs);
---

<Layout title={title} description={description} schemas={[plumberSchema, breadcrumb, faqSchema]}>
  <AnnounceBar city={data.city} phoneDisplay={data.phone.display} />
  <SiteHeader
    brandName={data.brand.name}
    logoUrl={data.brand.logoUrl}
    phoneDisplay={data.phone.display}
    phoneTel={data.phone.tel}
    conversionMode={data.conversionMode}
    whatsappNumber={data.whatsapp.number}
    whatsappMessage={whatsappMessage}
    leadsterEmbedId={data.leadsterEmbedId}
  />
  <Hero
    mode="urgency"
    city={data.city}
    keyword={data.keyword}
    phoneTel={data.phone.tel}
    phoneDisplay={data.phone.display}
    conversionMode={data.conversionMode}
    whatsappNumber={data.whatsapp.number}
    whatsappMessage={whatsappMessage}
    leadsterEmbedId={data.leadsterEmbedId}
    kpis={data.kpis}
    heroImage={data.heroImage}
    neighborhoods={data.neighborhoods}
  />
  <UrgencyInfo city={data.city} keyword={data.keyword} phoneDisplay={data.phone.display} faqs={urgencyFaqs} />
  <Services services={data.services} />
  <Differentials differentials={data.differentials} />
  <Steps keyword={data.keyword} />
  <Areas neighborhoods={data.neighborhoods} />
  <Testimonials testimonials={data.testimonials} />
  <FinalCTA
    city={data.city}
    phoneTel={data.phone.tel}
    phoneDisplay={data.phone.display}
    conversionMode={data.conversionMode}
    whatsappNumber={data.whatsapp.number}
    whatsappMessage={whatsappMessage}
    leadsterEmbedId={data.leadsterEmbedId}
  />
  <SiteFooter
    partnerName={data.partner.name}
    partnerAddress={data.partner.address}
    mapEmbedUrl={data.partner.mapEmbedUrl}
    phoneDisplay={data.phone.display}
    services={data.services}
    neighborhoods={data.neighborhoods}
    city={data.city}
  />
  <StickyMobileCta
    phoneTel={data.phone.tel}
    phoneDisplay={data.phone.display}
    conversionMode={data.conversionMode}
    whatsappNumber={data.whatsapp.number}
    whatsappMessage={whatsappMessage}
    leadsterEmbedId={data.leadsterEmbedId}
  />
</Layout>
